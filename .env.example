VITE_API_PROVIDER=google-sheets
VITE_GOOGLE_SHEETS_URL=https://script.google.com/macros/s/<DEPLOYMENT_ID>/exec
VITE_API_AUTH_TOKEN=
VITE_API_ALLOWED_HOSTS=script.google.com
VITE_INTERNAL_API_BASE_URL=
VITE_INTERNAL_API_ALLOWED_HOSTS=localhost,127.0.0.1
VITE_HEALTHCHECK_INTERVAL_MS=60000
VITE_HEALTHCHECK_WARN_LATENCY_MS=1500
VITE_HEALTHCHECK_ALERT_FAILURE_THRESHOLD=3
VITE_HEALTHCHECK_ALERT_COOLDOWN_MS=120000
VITE_OBSERVABILITY_SINK=console
VITE_ENABLE_DEBUG_LOGS=false
